# =============================================================================
# Django Core
# =============================================================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# Database (PostgreSQL Docker)
# =============================================================================
POSTGRES_DB=hepasense
POSTGRES_USER=hepasense
POSTGRES_PASSWORD=hepasense123
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# =============================================================================
# JWT Settings
# =============================================================================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# =============================================================================
# Email (Gmail example - optional)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@hepasense.com

# =============================================================================
# Cache
# =============================================================================
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=hepasense-cache

# =============================================================================
# Logging
# =============================================================================
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# Admin
# =============================================================================
ADMIN_EMAIL=admin@hepasense.com